{
  "scenario": "System hangs where lots of tasks waiting for page writeback to complete where vsapiapp is blocking in spinlock and prevent kthreadd from taking the CPU",
  "symptoms": [
    "rcu_sched detected stalls on CPUs/tasks: { 3}",
    "exception RIP: native_halt+5",
    "kvm_lock_spinning at ffffffff8105259a",
    "ioctlMod at ffffffffa04988eb [splxmod]",
    "closeHook at ffffffffa049a9cb [splxmod]",
    "Tasks stuck in TASK_UNINTERRUPTIBLE state for >120 seconds",
    "System hangs with tasks waiting for page writeback completion"
  ],
  "workflow": [
    {
      "step_number": 1,
      "thought": "Check system information and dump file details",
      "action": "sys",
      "observation": "System configuration and crash environment"
    },
    {
      "step_number": 2,
      "thought": "Get detailed system information including DMI data",
      "action": "sys -i",
      "observation": "Hardware and BIOS information"
    },
    {
      "step_number": 3,
      "thought": "Search for lockup, LOCKUP, blocked tasks, or rcu_sched stalls in kernel log",
      "action": "log | grep -e lockup -e LOCKUP -e blocked -e rcu_sched",
      "observation": "rcu_sched detected stalls on CPU 3"
    },
    {
      "step_number": 4,
      "thought": "Get backtrace for CPU 3 to see what's running",
      "action": "bt -c 3",
      "observation": "vsapiapp stuck at kvm_lock_spinning and ioctlMod"
    },
    {
      "step_number": 5,
      "thought": "Get process details for vsapiapp PID 11361",
      "action": "ps -a 11361",
      "observation": "vsapiapp from TrendMicro Server Protect for Linux"
    },
    {
      "step_number": 6,
      "thought": "Check what device the task is performing ioctl on",
      "action": "files -d 0xffff8800b39f79c0",
      "observation": "Device /dev/splxdev"
    },
    {
      "step_number": 7,
